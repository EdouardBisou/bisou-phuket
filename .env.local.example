# Sanity CMS - copy to .env.local and fill in
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

# Sanity write token (only needed for the seed script or revalidation endpoint)
SANITY_API_WRITE_TOKEN=

# Revalidation secret (protects /api/revalidate)
SANITY_REVALIDATE_SECRET=change_me

# Optional: Sanity Studio hosted URL
SANITY_STUDIO_URL=http://localhost:3000/studio
